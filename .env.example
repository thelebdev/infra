# infra platform-level environment variables.
# Copy this file to .env locally on the server and fill in the values.
# .env is gitignored. Never commit real secrets.

# === Server ===
# Public IP of the server. Optional; bootstrap uses the current host network.
SERVER_IP=

# REQUIRED. The unprivileged admin user — must NOT be `root`. bootstrap runs
# as root, but Docker and Claude Code are owned/run by this user.
# If left blank, scripts fall back to the owner of the repo checkout.
SERVER_ADMIN_USER=

# === Domain ===
# REQUIRED if you want Caddy + Authelia (SSO with TOTP) to serve dashboards
# and the Claude Code web terminal publicly with TLS.
# Caddy obtains and renews a Let's Encrypt cert automatically for the
# configured subdomains: auth.<domain>, claude.<domain>, dozzle.<domain>,
# glances.<domain>, ntopng.<domain> (and grafana.<domain> on full profile).
# Point DNS A records for those subdomains at the server's public IP BEFORE
# running bootstrap.sh, or Caddy's ACME challenge will fail.
# Leave blank for a localhost-only install (SSH-tunnel to view dashboards).
PRIMARY_DOMAIN=

# Email used for Let's Encrypt registration (renewal notices). REQUIRED if
# PRIMARY_DOMAIN is set.
CADDY_ACME_EMAIL=

# === SSO (Authelia) ===
# Authelia gates every subdomain under PRIMARY_DOMAIN with password + TOTP.
# AUTHELIA_USER defaults to `admin`.
# AUTHELIA_PASSWORD is auto-generated (32-char hex) if blank — copy the
# generated value into your secret store; you'll type it at login.
# Three internal secrets are also auto-generated to /opt/infra/platform/authelia/secrets/
# (never enter your .env). TOTP enrollment happens once during bootstrap:
# the server prints a QR code to scan into your authenticator app, and
# stashes the otpauth:// URI at /opt/infra/.authelia-enrollment.
AUTHELIA_USER=admin
AUTHELIA_PASSWORD=

# === Observability ===
# Which observability profile to deploy:
#   lightweight -> Glances + Dozzle + ntopng   (fits ~1 GiB RAM)
#   full        -> Loki + Prometheus + Grafana (>= 2 GiB RAM)
OBSERVABILITY_PROFILE=lightweight

# Grafana admin password (FULL profile only). Auto-generated on the server by
# 08-observability.sh if blank. Copy the generated value into your secret
# store. Leave blank here.
GRAFANA_ADMIN_PASSWORD=

# === Component selection ===
# Which optional components to install. Leave blank and bootstrap.sh prompts
# once on an interactive first run, writing your answer back here; an explicit
# true/false is used as-is, so re-runs and disaster-recovery runs are fully
# non-interactive. Blank with no terminal attached (CI) defaults to install.
# The mandatory hardened base (OS hardening, firewall, Docker) is never
# optional. INSTALL_GLANCES/DOZZLE/NTOPNG apply to the lightweight
# observability profile; the full profile is all-or-nothing.
INSTALL_GLANCES=
INSTALL_DOZZLE=
INSTALL_NTOPNG=
INSTALL_CLAUDE=
INSTALL_DASHBOARD=

# === Subdomain names ===
# The label for each component's subdomain under PRIMARY_DOMAIN. Blank uses
# the conventional name shown. bootstrap.sh offers to customize these on an
# interactive first run (one yes/no gate, then a prompt per component); an
# explicit value here is used as-is. Each must be a valid DNS label (lowercase
# letters, digits, hyphens). If your DNS uses a wildcard *.<domain> record any
# label resolves automatically; with explicit records, add one per label.
SUBDOMAIN_AUTH=
SUBDOMAIN_DASHBOARD=
SUBDOMAIN_CLAUDE=
SUBDOMAIN_DOZZLE=
SUBDOMAIN_GLANCES=
SUBDOMAIN_NTOPNG=
SUBDOMAIN_GRAFANA=

# === Remote management agent (Claude Code) ===
# Optional: lets 09-claude-code.sh wire non-interactive auth. If blank,
# authenticate interactively with `claude login` after bootstrap.
ANTHROPIC_API_KEY=

# Working directory the browser Claude session (claude.<PRIMARY_DOMAIN>) opens
# in. 07-ttyd.sh prompts for this on an interactive first install when it is
# blank, then writes the answer back here. On re-runs and disaster-recovery
# runs (where .env is already populated) it is used as-is with no prompt. The
# directory is created if it does not exist. If left blank and no terminal is
# attached (e.g. CI), it defaults to the admin user's home directory.
CLAUDE_WORKDIR=

# === Firewall ===
# Open public 80/443. Default true so Caddy can serve dashboards. Set to
# "false" only if you do not want any public web exposure (and you will
# reach dashboards via SSH port-forward).
ALLOW_PUBLIC_WEB=true

# === Backup ===
# Backup storage endpoint (e.g., Hetzner Storage Box or B2 bucket).
BACKUP_STORAGE_ENDPOINT=
BACKUP_STORAGE_ACCESS_KEY=
BACKUP_STORAGE_SECRET_KEY=

# Restic encryption passphrase.
BACKUP_ENCRYPTION_PASSPHRASE=

# === Alerting ===
# Email address that receives platform alerts.
ALERT_EMAIL=

# SMTP credentials for sending alerts.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

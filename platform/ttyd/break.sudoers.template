# Sudoers fragment for the TOTP-gated elevated commands inside the
# bubblewrap sandbox (rendered to /etc/sudoers.d/break by
# bootstrap/07-ttyd.sh with __ADMIN_USER__ substituted).
#
# The two allowed sudo commands inside the sandbox are:
#   /usr/local/sbin/break              — break out to an unconfined bash
#   /usr/local/sbin/claude-break-out   — break out and exec Claude Code
#                                        (typed as plain `claude` via
#                                        the shim at /usr/local/bin/claude)
#
# Both are pinned with PASSWD and a zero timestamp_timeout, so the
# operator's sudo password is required every single invocation (never
# cached from a recent sudo elsewhere), and both then prompt for a fresh
# Authelia TOTP code internally before doing anything.
#
# Any other `sudo <cmd>` inside the sandbox is rejected by sudoers — by
# design. The sandbox itself blocks the destructive effect of most root
# operations (`/` is read-only, `/home`/`/root`/`/tmp` are tmpfs), so the
# only legitimate elevated operations are these two break-outs.
#
# We deliberately do NOT add NOPASSWD or path-globbing — only the literal
# binaries below, only with PASSWD.

Defaults!/usr/local/sbin/break timestamp_timeout=0
Defaults!/usr/local/sbin/claude-break-out timestamp_timeout=0
__ADMIN_USER__ ALL=(ALL) PASSWD: /usr/local/sbin/break, /usr/local/sbin/claude-break-out

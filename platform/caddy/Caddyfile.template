# Caddy reverse proxy template — rendered to ./Caddyfile by
# bootstrap/06-caddy.sh, which substitutes the placeholders below and strips
# the server block of any component that was not selected at bootstrap.
#
# Placeholders (replaced literally at bootstrap time):
#   __PRIMARY_DOMAIN__      e.g. "example.com"
#   __CADDY_ACME_EMAIL__    Let's Encrypt registration email
#   __SUBDOMAIN_<NAME>__    the chosen label for each component's subdomain
#                           (AUTH, DASHBOARD, SESSIONS, DOZZLE, GLANCES,
#                           NTOPNG, GRAFANA) — defaults to the lowercase name
#
# Component blocks are wrapped in "# >>>component:NAME ... # <<<component:NAME"
# markers; 06-caddy.sh removes a block when that component is not installed,
# so Caddy never advertises a dead route or fetches an unused certificate.
#
# Auth model: Authelia is consulted on every request via forward_auth;
# unauthenticated requests are redirected to the Authelia portal where the
# operator authenticates with password + TOTP.

{
	email __CADDY_ACME_EMAIL__
}

(secure_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
}

# Same as secure_headers but relaxes X-Frame-Options to SAMEORIGIN so the
# mobile wrapper at /m/ can iframe the ttyd root on the same subdomain.
# Used only on the sessions vhost — every other vhost stays DENY.
(secure_headers_sessions) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
		-Server
	}
}

# Snippet: gate a route on a valid Authelia session.
#
# IMPORTANT — the *caller* must wrap this import inside a `route { }` block.
#
# Caddy reorders directives by priority. In particular:
#   request_header (header group) > forward_auth > handle > route > terminal.
# So a naked sequence of `import authelia_gate; handle /api/* { ... }` ends
# up running `handle /api/*` BEFORE the strips and forward_auth (handle's
# priority is higher than route's). The request reaches the upstream with
# no Remote-User, and session-manager returns 401 "missing or ambiguous
# identity" even though the user is logged in.
#
# Wrapping the *whole* site block contents in `route { ... }` forces
# source-order evaluation across imports + handle blocks. Don't try to put
# the `route` wrapper inside this snippet — that solves it only when the
# caller has no `handle` blocks (e.g. a single top-level reverse_proxy).
#
# The strips are also belt-and-suspenders against client-supplied Remote-User
# spoofing (CVE-2026-30851 / Caddy < v2.11.2). On v2.11.2+, copy_headers
# already deletes the request header before setting it from the auth response.
(authelia_gate) {
	request_header -Remote-User
	request_header -Remote-Groups
	request_header -Remote-Name
	request_header -Remote-Email
	forward_auth 127.0.0.1:9091 {
		uri /api/verify?rd=https%3A%2F%2F__SUBDOMAIN_AUTH__.__PRIMARY_DOMAIN__
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# The Authelia portal itself — never gated, always present.
__SUBDOMAIN_AUTH__.__PRIMARY_DOMAIN__ {
	import secure_headers
	reverse_proxy 127.0.0.1:9091
}

# >>>component:dashboard
# Platform landing page: the tool index plus the live "Terminal sessions"
# section. Reachable at the apex domain and the dashboard subdomain. Gated by
# Authelia.
#
# The `route { }` wrapper around `import authelia_gate` + the handle blocks
# is critical: without it, Caddy's directive-priority sort puts `handle`
# before the gate, so `/api/*` reverse-proxies to session-manager BEFORE
# forward_auth runs — the upstream sees no Remote-User and returns 401.
__PRIMARY_DOMAIN__, __SUBDOMAIN_DASHBOARD__.__PRIMARY_DOMAIN__ {
	import secure_headers
	route {
		import authelia_gate
# >>>component:sessions-api
		# The dashboard's "Terminal sessions" section calls the
		# session-manager API. Same origin, same Authelia gate — no
		# extra subdomain.
		handle /api/* {
			reverse_proxy 127.0.0.1:7682
		}
# <<<component:sessions-api
		handle {
			root * /srv/dashboard
			file_server
		}
	}
}
# <<<component:dashboard

# >>>component:sessions
# Browser terminal sessions (shell or Claude Code) via ttyd. Gated by Authelia.
#
# Mobile UX: /m/ serves a static wrapper page that iframes ttyd and overlays
# a CLI key bar (Esc, Tab, arrows, Ctrl-*, |, ~, /, ...). The wrapper also
# patches xterm.js's hidden helper textarea to disable iOS/Android first-letter
# capitalization, autocorrect, and autocomplete on every keystroke. Mobile
# user agents that hit `/` are 302'd to `/m/` so existing bookmarks "just work".
# Desktop UAs see the unmodified ttyd at `/` as before.
#
# Iframing requires X-Frame-Options to allow same-origin — see the
# secure_headers_sessions snippet above.
__SUBDOMAIN_SESSIONS__.__PRIMARY_DOMAIN__ {
	import secure_headers_sessions
	route {
		import authelia_gate

		# Mobile wrapper assets — static files under /srv/sessions-mobile.
		handle_path /m/* {
			root * /srv/sessions-mobile
			file_server
		}
		handle /m {
			redir /m/ 301
		}

		# Auto-route mobile UAs landing on `/` into the wrapper, preserving
		# the original ?arg=<session> query. `Mobi` matches Android Chrome
		# and Mobile Safari; `iPhone` belt-and-suspenders for older UAs.
		@sessions_mobile_root {
			path /
			header_regexp User-Agent (Mobi|Android|iPhone|iPod)
		}
		redir @sessions_mobile_root /m/?{query} 302

		reverse_proxy 127.0.0.1:7681
	}
}
# <<<component:sessions

# >>>component:dozzle
__SUBDOMAIN_DOZZLE__.__PRIMARY_DOMAIN__ {
	import secure_headers
	route {
		import authelia_gate
		reverse_proxy 127.0.0.1:8080
	}
}
# <<<component:dozzle


# Caddy reverse proxy template — rendered to ./Caddyfile by
# bootstrap/06-caddy.sh, which substitutes the placeholders below and strips
# the server block of any component that was not selected at bootstrap.
#
# Placeholders (replaced literally at bootstrap time):
#   __PRIMARY_DOMAIN__      e.g. "example.com"
#   __CADDY_ACME_EMAIL__    Let's Encrypt registration email
#   __SUBDOMAIN_<NAME>__    the chosen label for each component's subdomain
#                           (AUTH, DASHBOARD, SESSIONS, DOZZLE, GLANCES,
#                           NTOPNG, GRAFANA) — defaults to the lowercase name
#
# Component blocks are wrapped in "# >>>component:NAME ... # <<<component:NAME"
# markers; 06-caddy.sh removes a block when that component is not installed,
# so Caddy never advertises a dead route or fetches an unused certificate.
#
# Auth model: Authelia is consulted on every request via forward_auth;
# unauthenticated requests are redirected to the Authelia portal where the
# operator authenticates with password + TOTP.

{
	email __CADDY_ACME_EMAIL__
}

(secure_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
}

# Snippet: gate a route on a valid Authelia session.
(authelia_gate) {
	# Strip any client-supplied identity headers BEFORE consulting Authelia.
	# forward_auth's copy_headers only *sets* these from the auth response —
	# it never deletes a value the client sent (CVE-2026-30851 / Caddy <
	# v2.11.2). Without this strip a logged-in user could spoof Remote-User
	# and impersonate another, defeating the per-user session isolation.
	request_header -Remote-User
	request_header -Remote-Groups
	request_header -Remote-Name
	request_header -Remote-Email
	forward_auth 127.0.0.1:9091 {
		uri /api/verify?rd=https%3A%2F%2F__SUBDOMAIN_AUTH__.__PRIMARY_DOMAIN__
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# The Authelia portal itself — never gated, always present.
__SUBDOMAIN_AUTH__.__PRIMARY_DOMAIN__ {
	import secure_headers
	reverse_proxy 127.0.0.1:9091
}

# >>>component:dashboard
# Platform landing page: the tool index plus the live "Terminal sessions"
# section. Reachable at the apex domain and the dashboard subdomain. Gated by
# Authelia.
__PRIMARY_DOMAIN__, __SUBDOMAIN_DASHBOARD__.__PRIMARY_DOMAIN__ {
	import secure_headers
	import authelia_gate
# >>>component:sessions-api
	# The dashboard's "Terminal sessions" section calls the session-manager
	# API. Same origin, same Authelia gate — no extra subdomain. Authelia
	# runs first (forward_auth expands to a `route`, ordered before `handle`),
	# so the API always receives a verified Remote-User.
	handle /api/* {
		reverse_proxy 127.0.0.1:7682
	}
# <<<component:sessions-api
	handle {
		root * /srv/dashboard
		file_server
	}
}
# <<<component:dashboard

# >>>component:sessions
# Browser terminal sessions (shell or Claude Code) via ttyd. Gated by Authelia.
__SUBDOMAIN_SESSIONS__.__PRIMARY_DOMAIN__ {
	import secure_headers
	import authelia_gate
	reverse_proxy 127.0.0.1:7681
}
# <<<component:sessions


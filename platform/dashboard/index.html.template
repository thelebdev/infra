<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex, nofollow">
<title>Platform · __PRIMARY_DOMAIN__</title>
<style>
  :root {
    --bg: #0d1117; --surface: #161b22; --surface-2: #1c2330;
    --surface-hover: #222b39; --border: #30363d; --border-soft: #262c36;
    --text: #e6edf3; --muted: #8b949e; --faint: #6e7681;
    --accent: #58a6ff; --accent-dim: #1f6feb;
    --green: #3fb950; --red: #f85149; --yellow: #d29922;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background:
      radial-gradient(900px 360px at 80% -8%, #16243b 0%, transparent 70%),
      var(--bg);
    color: var(--text); min-height: 100vh; padding: 1.75rem 1.5rem 3rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
  }
  .wrap { max-width: 960px; margin: 0 auto; }
  code, .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  /* header */
  header { display: flex; align-items: baseline; gap: .75rem;
           flex-wrap: wrap; padding-bottom: 1.5rem; }
  h1 { font-size: 1.5rem; font-weight: 600; letter-spacing: -.01em; }
  .domain {
    font-size: .82rem; color: var(--accent);
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 999px; padding: .15rem .7rem;
  }
  h2 {
    font-size: .8rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .07em; color: var(--muted);
  }
  .section { margin-top: 2rem; }
  .section-head {
    display: flex; align-items: baseline; gap: .6rem;
    flex-wrap: wrap; margin-bottom: .9rem;
  }
  .section-head .hint { font-size: .82rem; color: var(--faint); }

  /* generic panel */
  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px;
  }

  /* tool cards */
  .grid {
    display: grid; gap: .85rem;
    grid-template-columns: repeat(auto-fill, minmax(224px, 1fr));
  }
  .card {
    display: flex; flex-direction: column; gap: .25rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 1rem 1.1rem;
    text-decoration: none; color: var(--text);
    transition: background .12s ease, border-color .12s ease, transform .12s ease;
  }
  .card:hover {
    background: var(--surface-hover); border-color: var(--accent);
    transform: translateY(-1px);
  }
  .card:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .card-name { font-weight: 600; font-size: 1.02rem; }
  .card-desc { color: var(--muted); font-size: .9rem; }
  .card-host {
    color: var(--accent); font-size: .8rem; margin-top: .35rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    word-break: break-all;
  }
  /* per-session card markers (added dynamically next to the static tools) */
  .card.session-card .card-name { display: flex; align-items: center; gap: .45rem; }
  .card.session-card .dot {
    display: inline-block; width: .55rem; height: .55rem; border-radius: 50%;
    border: 1.5px solid var(--green); flex: 0 0 auto;
  }
  .card.session-card .dot.attached { background: var(--green); }
  .card.session-card .card-cmd {
    font-size: .72rem; color: var(--muted);
    border: 1px solid var(--border); border-radius: 999px;
    padding: 0 .45rem; line-height: 1.4; margin-left: auto;
  }

  /* sessions */
  .sessions { padding: 1.15rem 1.2rem 1.3rem; }
  .new-session { display: flex; gap: .55rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .new-session input, .new-session select {
    flex: 1 1 200px; min-width: 0;
    background: var(--bg); color: var(--text);
    border: 1px solid var(--border); border-radius: 8px;
    padding: .55rem .7rem; font-size: .9rem;
  }
  .new-session select { flex: 0 1 140px; }
  .new-session input:focus, .new-session select:focus {
    outline: none; border-color: var(--accent);
  }
  button, .btn {
    font: inherit; font-size: .86rem; cursor: pointer;
    border-radius: 8px; border: 1px solid var(--border);
    background: var(--surface-2); color: var(--text);
    padding: .5rem .85rem; text-decoration: none;
    transition: background .12s ease, border-color .12s ease;
  }
  button:hover, .btn:hover { background: var(--surface-hover); border-color: var(--accent); }
  button:disabled { opacity: .5; cursor: progress; }
  .new-session button { background: var(--accent-dim); border-color: var(--accent-dim); }
  .new-session button:hover { background: var(--accent); border-color: var(--accent); }

  .srow {
    display: grid; align-items: center;
    grid-template-columns: minmax(110px,1fr) minmax(0,2.2fr) auto auto;
    gap: .75rem; padding: .6rem .35rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .srow:last-child { border-bottom: 0; }
  .srow.head {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .06em;
    color: var(--faint); padding-bottom: .4rem;
  }
  .scol-name { font-weight: 600; }
  .scol-dir {
    color: var(--muted); font-size: .85rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .scol-act { display: flex; gap: .4rem; justify-content: flex-end; }
  .btn.open { color: var(--accent); }
  .btn.stop:hover { border-color: var(--red); color: var(--red); }
  .badge {
    font-size: .74rem; padding: .12rem .5rem; border-radius: 999px;
    border: 1px solid var(--border);
  }
  .badge.live { color: var(--green); border-color: #2c5331; background: #122119; }
  .badge.idle { color: var(--faint); }
  .banner {
    font-size: .85rem; color: var(--red);
    background: #2a1416; border: 1px solid #5c2a2a;
    border-radius: 8px; padding: .55rem .75rem; margin-bottom: .8rem;
  }
  .banner.drift {
    color: var(--yellow);
    background: #2a2414; border-color: #5c4a2a;
    margin-top: 1.5rem;
  }
  .banner.drift strong { color: var(--yellow); }
  .muted { color: var(--muted); }
  .pad { padding: .8rem .35rem; font-size: .9rem; }

  /* users panel */
  .users { padding: 1.1rem 1.2rem; }
  .users p { color: var(--muted); font-size: .92rem; }
  .users code {
    display: block; margin-top: .7rem; padding: .7rem .85rem;
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
    font-size: .85rem; color: var(--text); overflow-x: auto;
  }

  footer {
    margin-top: 2.5rem; padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    color: var(--faint); font-size: .82rem;
  }
  @media (max-width: 560px) {
    body { padding: 1.1rem 1rem 2.5rem; }
    .srow { grid-template-columns: 1fr auto; row-gap: .3rem; }
    .srow.head { display: none; }
    .scol-dir { grid-column: 1 / -1; }
    .scol-act { grid-column: 1 / -1; justify-content: flex-start; }
  }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>Platform</h1>
    <span class="domain mono">__PRIMARY_DOMAIN__</span>
  </header>

  <!-- >>>sessions -->
  <section class="section">
    <div class="section-head">
      <h2>Terminal sessions</h2>
      <span class="hint">persistent &amp; per-user — survive a refresh, a logoff, or a dropped connection</span>
    </div>
    <div class="panel sessions">
      <form class="new-session" id="ns-form" autocomplete="off">
        <input type="text" id="ns-name" placeholder="new session name — e.g. api"
               pattern="[A-Za-z0-9][A-Za-z0-9_-]{0,31}"
               title="letters, digits, _ and - (max 32)" required>
        <input type="text" id="ns-dir" list="ws-dirs"
               placeholder="project directory (blank = workspace root)">
        <datalist id="ws-dirs"></datalist>
        <select id="ns-cmd" title="What to run in the session">
          <option value="shell" selected>Shell</option>
          <option value="claude" id="ns-cmd-claude">Claude Code</option>
        </select>
        <button type="submit">Start session</button>
      </form>
      <div class="banner" id="ns-error" hidden></div>
      <div id="ns-list"><div class="pad muted">loading…</div></div>
    </div>
  </section>
  <script>
  (function () {
    "use strict";
    var SESSIONS_BASE = "__SESSIONS_BASE_URL__";
    var listEl = document.getElementById("ns-list");
    var errEl = document.getElementById("ns-error");
    var form = document.getElementById("ns-form");
    var nameEl = document.getElementById("ns-name");
    var dirEl = document.getElementById("ns-dir");
    var cmdEl = document.getElementById("ns-cmd");
    var cmdClaudeOpt = document.getElementById("ns-cmd-claude");
    var dirList = document.getElementById("ws-dirs");
    var timer = null;

    function esc(s) {
      return String(s).replace(/[&<>"]/g, function (c) {
        return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
      });
    }
    function rel(sec) {
      if (sec < 90) return "active";
      if (sec < 3600) return Math.floor(sec / 60) + "m idle";
      if (sec < 86400) return Math.floor(sec / 3600) + "h idle";
      return Math.floor(sec / 86400) + "d idle";
    }
    function showError(msg) { errEl.textContent = msg || ""; errEl.hidden = !msg; }

    function api(method, path, body) {
      var opts = { method: method, headers: {} };
      if (body) {
        opts.headers["Content-Type"] = "application/json";
        opts.body = JSON.stringify(body);
      }
      return fetch(path, opts).then(function (res) {
        return res.json().catch(function () { return {}; }).then(function (d) {
          if (!res.ok) throw new Error(d.error || ("HTTP " + res.status));
          return d;
        });
      });
    }

    var toolsGridEl = document.getElementById("tools-grid");

    function renderSessionCards(sessions) {
      if (!toolsGridEl) return;
      // Drop the previously-injected per-session cards; static tool cards
      // stay because they don't carry .session-card.
      var stale = toolsGridEl.querySelectorAll(".card.session-card");
      for (var i = 0; i < stale.length; i++) stale[i].remove();
      // Prepend the freshest sessions first so they appear near the static
      // Terminal-sessions card, before Dozzle / Glances / etc.
      var anchor = toolsGridEl.firstChild;
      for (var j = 0; j < sessions.length; j++) {
        var s = sessions[j];
        var url = SESSIONS_BASE + "/?arg=" + encodeURIComponent(s.name);
        var dotCls = s.attached ? "dot attached" : "dot";
        var stateText = s.attached ? "attached" : rel(s.idle_seconds);
        var cmd = s.cmd || "shell";
        var node = document.createElement("a");
        node.className = "card session-card";
        node.href = url;
        node.target = "_blank";
        node.rel = "noopener";
        node.innerHTML =
          '<span class="card-name">' +
            '<span class="' + dotCls + '"></span>' +
            esc(s.name) +
            '<span class="card-cmd">' + esc(cmd) + '</span>' +
          '</span>' +
          '<span class="card-desc">' + esc(stateText) +
            ' · ' + (s.windows || 1) + 'w · ' + esc(s.dir) + '</span>' +
          '<span class="card-host">open this session ↗</span>';
        toolsGridEl.insertBefore(node, anchor);
      }
    }

    function render(sessions) {
      renderSessionCards(sessions);
      if (!sessions.length) {
        listEl.innerHTML = '<div class="pad muted">No sessions yet — '
          + 'start one above. Each is an independent terminal session.</div>';
        return;
      }
      var head = '<div class="srow head"><div>Session</div><div>Directory</div>'
        + '<div>State</div><div></div></div>';
      var rows = sessions.map(function (s) {
        var url = SESSIONS_BASE + "/?arg=" + encodeURIComponent(s.name);
        var badge = s.attached
          ? '<span class="badge live">attached</span>'
          : '<span class="badge idle">' + esc(rel(s.idle_seconds)) + '</span>';
        var cmdBadge = '<span class="badge">' + esc(s.cmd || "shell") + '</span>';
        return '<div class="srow">'
          + '<div class="scol-name">' + esc(s.name) + ' ' + cmdBadge + '</div>'
          + '<div class="scol-dir" title="' + esc(s.dir) + '">' + esc(s.dir) + '</div>'
          + '<div>' + badge + ' <span class="muted">' + (s.windows || 1) + 'w</span></div>'
          + '<div class="scol-act">'
          + '<a class="btn open" href="' + esc(url) + '" target="_blank" rel="noopener">Open &#8599;</a>'
          + '<button class="btn stop" data-name="' + esc(s.name) + '">Stop</button>'
          + '</div></div>';
      });
      listEl.innerHTML = head + rows.join("");
    }

    function loadCapabilities() {
      return api("GET", "/api/capabilities").then(function (d) {
        if (cmdClaudeOpt && d && d.claude_installed === false) {
          cmdClaudeOpt.disabled = true;
          cmdClaudeOpt.textContent = "Claude Code (unavailable)";
        }
      }).catch(function () {});
    }

    function refresh() {
      return api("GET", "/api/sessions").then(function (d) {
        showError("");
        render(d.sessions || []);
      }).catch(function (e) {
        showError("Could not load sessions: " + e.message);
      });
    }
    function loadDirs() {
      return api("GET", "/api/workspace").then(function (d) {
        dirList.innerHTML = (d.dirs || []).map(function (x) {
          return '<option value="' + esc(x) + '"></option>';
        }).join("");
      }).catch(function () {});
    }

    listEl.addEventListener("click", function (ev) {
      var btn = ev.target.closest && ev.target.closest(".btn.stop");
      if (!btn) return;
      var name = btn.getAttribute("data-name");
      if (!window.confirm('Stop "' + name + '"? Its process ends.')) return;
      btn.disabled = true;
      api("DELETE", "/api/sessions/" + encodeURIComponent(name))
        .then(refresh)
        .catch(function (e) {
          showError("Could not stop " + name + ": " + e.message);
          btn.disabled = false;
        });
    });

    form.addEventListener("submit", function (ev) {
      ev.preventDefault();
      var name = nameEl.value.trim();
      if (!name) return;
      var submit = form.querySelector("button");
      submit.disabled = true;
      api("POST", "/api/sessions", {
        name: name,
        dir: dirEl.value.trim(),
        cmd: (cmdEl && cmdEl.value) || "shell"
      })
        .then(function () {
          nameEl.value = ""; dirEl.value = "";
          if (cmdEl) cmdEl.value = "shell";
          return Promise.all([refresh(), loadDirs()]);
        })
        .catch(function (e) { showError("Could not start " + name + ": " + e.message); })
        .then(function () { submit.disabled = false; });
    });

    function start() {
      if (timer) clearInterval(timer);
      timer = setInterval(refresh, 5000);
    }
    document.addEventListener("visibilitychange", function () {
      if (document.hidden) { clearInterval(timer); }
      else { refresh(); start(); }
    });
    refresh();
    loadDirs();
    loadCapabilities();
    start();
  })();
  </script>
  <!-- <<<sessions -->

  <section class="section">
    <div class="section-head"><h2>Tools</h2></div>
    <div class="grid" id="tools-grid">
      __SESSIONS_CARD__
      __DOZZLE_CARD__
      __GLANCES_CARD__
      __NTOPNG_CARD__
      __GRAFANA_CARD__
      <a class="card" href="https://__SUBDOMAIN_AUTH__.__PRIMARY_DOMAIN__">
        <span class="card-name">Authelia</span>
        <span class="card-desc">SSO portal and your 2FA settings</span>
        <span class="card-host">__SUBDOMAIN_AUTH__.__PRIMARY_DOMAIN__</span>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="section-head"><h2>Users</h2></div>
    <div class="panel users">
      <p>
        Every tool here is gated by Authelia single sign-on (password + TOTP).
        To grant someone access, add an Authelia user from an SSH session on
        the server:
      </p>
      <code>sudo /opt/infra/platform/authelia/add-user.sh &lt;username&gt;</code>
      <p style="margin-top:.7rem">
        The script sets the password, enrols a TOTP device, and prints the
        enrolment QR. Each user gets their own private set of terminal sessions.
      </p>
    </div>
  </section>

  <div class="banner drift" id="drift-banner" hidden></div>

  <footer>
    Platform layer · gated by Authelia SSO · served by Caddy.<br>
    <span id="version-info" class="muted">version: <span class="mono">loading…</span></span>
  </footer>
  <script>
  (function () {
    "use strict";
    function esc(s) {
      return String(s).replace(/[&<>"]/g, function (c) {
        return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
      });
    }
    function shortTs(ts) {
      // "2026-05-26T10:30:00Z" -> "2026-05-26 10:30Z"
      if (!ts || typeof ts !== "string") return "";
      return ts.replace("T", " ").replace(/:\d\d(?=Z|\+|-|$)/, "");
    }
    fetch("/api/version", { headers: { "Accept": "application/json" } })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var info = document.getElementById("version-info");
        if (!info) return;
        var head = '<span class="mono">' + esc(d.git_sha || "?") + '</span>';
        var comps = d.components || {};
        var rows = [];
        Object.keys(comps).forEach(function (k) {
          var c = comps[k];
          if (c) {
            var sha = String(c.git_sha || "?").split("-")[0].slice(0, 7);
            rows.push(esc(k) + " " + sha + " @ " + esc(shortTs(c.rendered_at)));
          } else {
            rows.push(esc(k) + " <em>never rendered</em>");
          }
        });
        info.innerHTML = "version: " + head + " &middot; " + rows.join(" &middot; ");
        if (d.drift) {
          var w = document.getElementById("drift-banner");
          if (w) {
            w.hidden = false;
            w.innerHTML = "<strong>Configuration drift.</strong> "
              + "These components were rendered against an older commit than the current HEAD ("
              + esc(d.git_sha) + "): <span class=\"mono\">"
              + esc((d.drifted_components || []).join(", "))
              + "</span>. Re-run <span class=\"mono\">sudo ./bootstrap/bootstrap.sh</span> on the server.";
          }
        }
      })
      .catch(function () {
        var info = document.getElementById("version-info");
        if (info) info.textContent = "version: (unavailable)";
      });
  })();
  </script>
</div>
</body>
</html>
